# Только то, что GitHub физически не примет или бессмысленно бэкапить.
# Всё остальное — в репозиторий (полный тяжёлый бэкап).

# Python venv — содержат файлы >100MB (torch.dll 294MB), пересоздаются из pip
.venv/
.venv312/
**/.venv/
**/.venv312/

# Python кеши
__pycache__/
*.py[cod]

# Записанные демо (данные, пересоздаются записью; конвертятся в LeRobot отдельно)
**/recordings/

# Внутренности вложенных репозиториев (попадали при шелвинге)
.git_shelved/
**/.git_shelved/

# Sensitive — network credentials, backups, local secrets
pi-config/network/50-cloud-init.yaml
pi-backup/
.env
*.env.local
